# Copy to .env and fill in to enable AI-generated questions.
# Without a key, Lex Arena runs fully on its built-in template generator.

# Anthropic API key (optional). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model used for question generation (optional)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server port (optional, defaults to 3000)
PORT=3000
